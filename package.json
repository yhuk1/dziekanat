{
  "name": "dziekanat-gra-o-zaliczenie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "node scripts/resolve-vercel-migration.mjs && prisma migrate deploy --schema prisma/postgres/schema.prisma && prisma generate --schema prisma/postgres/schema.prisma && node prisma/seed.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test --experimental-strip-types src/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:postgres:generate": "prisma generate --schema prisma/postgres/schema.prisma",
    "prisma:postgres:migrate": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "6.13.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.4.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "6.13.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
